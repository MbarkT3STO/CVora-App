{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./netlify/functions-build",
    "rootDir": "./netlify/functions",
    "lib": ["ES2020"],
    "types": ["node"]
  },
  "include": ["netlify/functions/**/*"],
  "exclude": ["node_modules"]
}
